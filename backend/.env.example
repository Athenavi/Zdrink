# 安全密钥
SECRET_KEY=your-secret-key-here

# 调试模式
DEBUG=True

# 数据库配置
DATABASE_URL=postgresql+psycopg2://user:password@localhost/database_name

# 微信支付配置（V3 API）
WECHAT_PAY_APP_ID=your_wechat_appid
WECHAT_PAY_MCH_ID=your_merchant_id
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial_number
WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/api/payments/callback/wechat/

# 支付宝配置
ALIPAY_APP_ID=your_alipay_appid
ALIPAY_APP_PRIVATE_KEY=your_app_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/payments/callback/alipay/
ALIPAY_RETURN_URL=https://yourdomain.com/payment/result/
ALIPAY_DEBUG=False  # 测试环境设为True，生产环境设为False

# ==================== 第三方登录配置 ====================
# 微信开放平台配置（网站应用扫码登录）
WEIXIN_APP_ID=your_weixin_appid
WEIXIN_APP_SECRET=your_weixin_app_secret

# 支付宝开放平台配置
ALIPAY_LOGIN_APP_ID=your_alipay_login_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key_for_login
ALIPAY_PUBLIC_KEY=your_alipay_public_key_for_login